# Backend configuration
PORT=3000

# PostgreSQL connection options
# Option 1: Using a connection string (Recommended for Render, Neon, Supabase)
DATABASE_URL=postgresql://user:password@hostname:5432/database_name?sslmode=require

# Option 2: Using individual parameters (Alternative)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=your_user
# DB_PASSWORD=your_password
# DB_NAME=your_database